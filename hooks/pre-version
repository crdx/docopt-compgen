#!/bin/bash
set -euo pipefail

NEW_VERSION="$1"

sed -i "s/VERSION = .*/VERSION = '${NEW_VERSION}'/" lib/*/version.rb
bundle install

git add lib/*/version.rb Gemfile.lock CHANGELOG.md
if git diff --cached --quiet; then
    echo "Nothing to commit (files already committed)."
else
    git commit -m "Release v${NEW_VERSION}"
fi
